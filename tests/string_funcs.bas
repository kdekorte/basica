10 A$ = "HELLO WORLD"
20 PRINT "1:";LEFT$(A$,5)
30 PRINT "2:";RIGHT$(A$,5)
40 PRINT "3:";MID$(A$,7,5)
50 PRINT "4:";MID$(A$,7)
