10 SCREEN 1
20 DIM A(15)
25 DIM C(15)
30 REM INITIALIZE WITH RANDOM HEIGHTS
40 FOR I = 1 TO 15
41 A(I) = INT(RND * 150) + 10
42 C(I) = INT(RND * 3) + 1
43 NEXT I
50 CLS : GOSUB 500 : REM INITIAL DRAW
60 REM BUBBLE SORT
70 FOR I = 1 TO 14
80 FOR J = 1 TO 15 - I
90 IF A(J) > A(J+1) THEN GOSUB 600: SWAP A(J), A(J+1): SWAP C(J), C(J+1): GOSUB 700: SLEEP 10
100 NEXT J
110 NEXT I
120 LOCATE 1,1: PRINT "SORTED!"
130 END
500 REM DRAWING ROUTINE
520 FOR K = 1 TO 15
530 X = K * 20
540 LINE (X, 180)-(X + 10, 180 - A(K)), C(K), BF
550 NEXT K
560 RETURN
600 REM ERASE BARS J AND J+1
610 X = J * 20 : LINE (X - 5, 199)-(X + 15, 0), 0, BF
620 X = (J + 1) * 20 : LINE (X - 5, 199)-(X + 15, 0), 0, BF
630 RETURN
700 REM REDRAW BARS J AND J+1
710 X = J * 20 : LINE (X, 180)-(X + 10, 180 - A(J)), C(J), BF
720 X = (J + 1) * 20 : LINE (X, 180)-(X + 10, 180 - A(J + 1)), C(J + 1), BF
730 RETURN