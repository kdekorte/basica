10 REM ON KEY(n) Demo for BASICA
20 SCREEN 0: CLS
30 COLOR 14: LOCATE 1,1: PRINT "ON KEY(n) DEMO"
40 COLOR 7: LOCATE 3,1: PRINT "Run with -w. Click the window, then press F1/F2 and cursor keys."
50 COLOR 7: LOCATE 5,1: PRINT "F1    : "; F1
60 LOCATE 6,1: PRINT "F2    : "; F2
70 LOCATE 7,1: PRINT "UP    : "; U
80 LOCATE 8,1: PRINT "LEFT  : "; L
90 LOCATE 9,1: PRINT "RIGHT : "; R
100 LOCATE 10,1: PRINT "DOWN  : "; D
110 LOCATE 12,1: PRINT "Press Esc or Ctrl+C to quit."
120 KEY(1) ON
130 KEY(2) ON
140 KEY(11) ON
150 KEY(12) ON
160 KEY(13) ON
170 KEY(14) ON
180 ON KEY(1) GOSUB 2000
190 ON KEY(2) GOSUB 2010
200 ON KEY(11) GOSUB 2020
210 ON KEY(12) GOSUB 2030
220 ON KEY(13) GOSUB 2040
230 ON KEY(14) GOSUB 2050
240 SLEEP 20
250 GOTO 240
2000 F1 = F1 + 1: LOCATE 5,10: PRINT USING "#####", F1: RETURN
2010 F2 = F2 + 1: LOCATE 6,10: PRINT USING "#####", F2: RETURN
2020 U = U + 1: LOCATE 7,10: PRINT USING "#####", U: RETURN
2030 L = L + 1: LOCATE 8,10: PRINT USING "#####", L: RETURN
2040 R = R + 1: LOCATE 9,10: PRINT USING "#####", R: RETURN
2050 D = D + 1: LOCATE 10,10: PRINT USING "#####", D: RETURN
