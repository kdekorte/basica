10 REM ON TIMER(n) Demo for BASICA
20 SCREEN 0: CLS
30 START = TIMER
40 TICKS = 0
50 COLOR 14: LOCATE 1,1: PRINT "ON TIMER(n) DEMO"
60 COLOR 7: LOCATE 3,1: PRINT "Run with -w. The counter updates once per second."
70 LOCATE 5,1: PRINT "Ticks : "; TICKS
80 LOCATE 6,1: PRINT "Start : "; START
90 TIMER ON
100 ON TIMER(1) GOSUB 2000
110 SLEEP 20
120 GOTO 110
2000 TICKS = TICKS + 1
2010 LOCATE 5,9: PRINT USING "#####", TICKS
2020 RETURN
