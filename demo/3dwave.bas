10 SCREEN 1: CLS
20 CX = 160: CY = 100: SCALE = 4
30 REM 45 DEGREES IN RADIANS
40 RX = 0.7854: RY = 0.7854: RZ = 0.7854
50 FOR Z = -25 TO 25 STEP 1
60   FIRST = 1
70   FOR X = -25 TO 25 STEP 1
80     D = SQR(X*X + Z*Z)
90     Y = 0: IF D > 0 THEN Y = 12 * SIN(D) / D
100    REM ROTATE AROUND Y AXIS
110    X1 = X * COS(RY) - Z * SIN(RY)
120    Z1 = X * SIN(RY) + Z * COS(RY)
130    REM ROTATE AROUND X AXIS
140    Y1 = Y * COS(RX) - Z1 * SIN(RX)
150    REM ROTATE AROUND Z AXIS AND PROJECT
160    NX = CX + (X1 * COS(RZ) - Y1 * SIN(RZ)) * SCALE: NY = CY - (X1 * SIN(RZ) + Y1 * COS(RZ)) * SCALE
170    IF FIRST = 0 THEN LINE (PX,PY)-(NX,NY), 3
180    PX = NX: PY = NY: FIRST = 0
190   NEXT X
200 NEXT Z
210 LOCATE 23, 1: PRINT "3D WAVE - 45 DEGREE TRIPLE TILT"
220 END