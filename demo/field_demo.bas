10 REM FIELD/LSET/RSET Demo for BASICA
20 OPEN "field_demo.dat" FOR RANDOM AS #1
30 FIELD #1, 12 AS NAME$, 12 AS CITY$, 6 AS ZIP$
40 LSET NAME$ = "BASICA"
50 LSET CITY$ = "DENVER"
60 RSET ZIP$ = "80202"
70 PUT #1, 1
80 LSET NAME$ = ""
90 LSET CITY$ = ""
100 LSET ZIP$ = ""
110 GET #1, 1
120 PRINT "["; NAME$; "]"
130 PRINT "["; CITY$; "]"
140 PRINT "["; ZIP$; "]"
150 CLOSE #1
160 END
