10 REM BASICA TV COLOR BAR TEST PATTERN
20 SCREEN 12: CLS
30 COLOR 15
40 LOCATE 1,18: PRINT "BASICA TV COLOR BAR TEST"
50 REM Draw the main color bars
60 FOR I = 0 TO 7
70   X1 = I * 80
80   X2 = X1 + 79
90   BAR_COLOR = 8 + I
100  IF BAR_COLOR > 15 THEN BAR_COLOR = 15
110  LINE (X1,120)-(X2,420), BAR_COLOR, BF
120 NEXT I
130 REM Add top white/black boxes
140 LINE (0,50)-(159,115), 15, BF
150 LINE (160,50)-(319,115), 0, BF
160 LINE (320,50)-(479,115), 15, BF
170 LINE (480,50)-(639,115), 7, BF
180 COLOR 14
190 LOCATE 24,1: PRINT "Press any key to quit..."
200 END
