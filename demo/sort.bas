10 SCREEN 1
20 DIM A(15)
25 DIM C(15)
30 REM INITIALIZE WITH RANDOM HEIGHTS
40 FOR I = 1 TO 15
41 A(I) = RND * 150 + 10
42 C(I) = INT(RND * 3) + 1
43 NEXT I
50 GOSUB 500 : REM INITIAL DRAW
60 REM BUBBLE SORT
70 FOR I = 1 TO 14
80 FOR J = 1 TO 15 - I
90 IF A(J) > A(J+1) THEN T = A(J): A(J) = A(J+1): A(J+1) = T: TC = C(J): C(J) = C(J+1): C(J+1) = TC: GOSUB 500: SLEEP 50
100 NEXT J
110 NEXT I
120 PRINT "SORTED!"
130 END
500 REM DRAWING ROUTINE
510 CLS : REM CLEAR SCREEN
520 FOR K = 1 TO 15
530 X = K * 20
540 LINE (X, 180)-(X + 10, 180 - A(K)), C(K), BF
550 NEXT K
560 RETURN
